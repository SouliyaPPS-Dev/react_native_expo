{
  "expo": {
    "name": "Buddhaword",
    "slug": "Buddhaword",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logotype.png",
    "scheme": "buddhaword",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "newArchEnabled": true,
      "supportsTablet": true,
      "bundleIdentifier": "com.souliyappsdev.buddhaword"
    },
    "android": {
      "newArchEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logotype.png",
        "backgroundColor": "#FFAF5D"
      },
      "package": "com.souliyappsdev.buddhaword"
    },
    "web": {
      "build": {
        "babel": {
          "plugins": [
            "expo-asset/babel"
          ]
        }
      },
      "bundler": "metro",
      "svg": true,
      "output": "static",
      "favicon": "./assets/images/logotype.png",
      "manifest": {
        "short_name": "Buddhaword",
        "name": "Buddhaword",
        "start_url": "/?source=pwa",
        "display": "standalone",
        "background_color": "#FFAF5D",
        "theme_color": "#FFAF5D",
        "icons": [
          {
            "src": "./dist/icons/Icon-192.png",
            "type": "image/png",
            "sizes": "192x192"
          },
          {
            "src": "./dist/icons/Icon-512.png",
            "type": "image/png",
            "sizes": "512x512"
          }
        ]
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logotype.png",
          "imageWidth": 200,
          "resizeMode": "cover",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "47ccf16b-47d6-463d-bcbd-32ef4165f2b7"
      },
      "SUTRA_API_URL": "https://sheets.googleapis.com/v4/spreadsheets/1mKtgmZ_Is4e6P3P5lvOwIplqx7VQ3amicgienGN9zwA/values/Sheet1!1:1000000?key=AIzaSyDFjIl-SEHUsgK0sjMm7x0awpf8tTEPQjs",
      "BOOK_API_URL": "https://sheets.googleapis.com/v4/spreadsheets/1mKtgmZ_Is4e6P3P5lvOwIplqx7VQ3amicgienGN9zwA/values/books!1:1000000?key=AIzaSyDFjIl-SEHUsgK0sjMm7x0awpf8tTEPQjs",
      "CALENDAR_API_URL": "https://sheets.googleapis.com/v4/spreadsheets/1mKtgmZ_Is4e6P3P5lvOwIplqx7VQ3amicgienGN9zwA/values/calendar!1:1000000?key=AIzaSyDFjIl-SEHUsgK0sjMm7x0awpf8tTEPQjs"
    },
    "owner": "souliyappsdev"
  }
}