{
  "name": "buddhaword",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "build:web": "expo export -p web && npx workbox-cli generateSW workbox-config.js",
    "predeploy": "expo export -p web",
    "deploy-hosting": "npm run predeploy && firebase deploy --only hosting",
    "preview": "eas build --platform android --profile preview",
    "production": "eas build --platform android --profile production"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/config-plugins": "~9.0.0",
    "@expo/metro-runtime": "~4.0.0",
    "@expo/prebuild-config": "~8.0.0",
    "@expo/vector-icons": "^14.0.2",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "dotenv": "^16.4.5",
    "eas-cli": "^13.4.1",
    "eslint": "^9.15.0",
    "expo": "^52.0.11",
    "expo-asset": "^11.0.1",
    "expo-blur": "~14.0.1",
    "expo-constants": "~17.0.3",
    "expo-font": "~13.0.1",
    "expo-haptics": "~14.0.0",
    "expo-image": "~2.0.2",
    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.9",
    "expo-splash-screen": "~0.29.13",
    "expo-status-bar": "~2.0.0",
    "expo-symbols": "~0.2.0",
    "expo-system-ui": "~4.0.4",
    "expo-web-browser": "~14.0.1",
    "firebase-tools": "^13.27.0",
    "metro-config": "^0.81.0",
    "react": "18",
    "react-dom": "18",
    "react-native": "^0.76.3",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-web": "~0.19.13",
    "react-native-webview": "13.12.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
